// External OBJ via `mesh src=` (CLI only — the browser demo can't load files).
// The path resolves next to this .scene file.
scene {
    background color=(0.02 0.03 0.03)

    material "jade" base-color=(0.2 0.7 0.5)

    camera position=(3 2.5 4) look-at=(0 0.5 0) fov=50
    light direction=(-1 -1.5 -0.6) intensity=1.3 ambient=0.2

    plane scale=(8 1 8)
    mesh "pyramid" src="assets/pyramid.obj" translate=(0 0 0) scale=1.4 material="jade"
}
