// Primitives-only (browser-safe): a lit ground with two balls and a box.
scene {
    background color=(0.02 0.02 0.05)

    material "red"  base-color=(0.85 0.25 0.2)
    material "blue" base-color=(0.25 0.45 0.9)

    camera position=(4 3 6) look-at=(0 0.6 0) fov=50
    light direction=(-1 -2 -1) intensity=1.3 ambient=0.18

    plane scale=(10 1 10)

    sphere "left"  translate=(-1.6 0.6 0) scale=0.6 material="red"
    sphere "right" translate=(1.6 0.6 0)  scale=0.6 material="blue"
    cube   "box"   translate=(0 0.5 -0.5) material="red"
}
