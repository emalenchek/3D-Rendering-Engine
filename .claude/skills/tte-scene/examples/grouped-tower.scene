// Nested transform groups: a stack of shrinking, rotated cubes on a plinth.
scene {
    background color=(0.03 0.03 0.04)

    material "stone" base-color=(0.7 0.7 0.72)
    material "gold"  base-color=(0.9 0.7 0.2)

    camera position=(5 4 7) look-at=(0 1.2 0) fov=48
    light direction=(-0.6 -1 -0.4) intensity=1.2 ambient=0.2

    plane scale=(12 1 12) material="stone"

    node "tower" translate=(0 0.5 0) {
        cube material="stone"
        node translate=(0 1 0) rotate=(0 20 0) {
            cube scale=(0.75 0.9 0.75) material="stone"
            node translate=(0 1 0) rotate=(0 20 0) {
                cube scale=(0.55 0.8 0.55) material="gold"
            }
        }
    }
}
